rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isWorkspaceMember(workspaceId) {
      return isSignedIn()
        && request.auth.uid in get(/databases/$(database)/documents/workspaces/$(workspaceId)).data.memberIds;
    }

    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    match /invite_codes/{code} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
    }

    match /workspaces/{workspaceId} {
      allow read: if isWorkspaceMember(workspaceId);
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.ownerId;
      allow update: if isWorkspaceMember(workspaceId)
        || (
          isSignedIn()
          && request.auth.uid in request.resource.data.memberIds
          && !(request.auth.uid in resource.data.memberIds)
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['memberIds'])
        );

      match /tickets/{ticketId} {
        allow read, write: if isWorkspaceMember(workspaceId);

        match /comments/{commentId} {
          allow read, create: if isWorkspaceMember(workspaceId);
          allow update, delete: if isSignedIn() && request.auth.uid == resource.data.userId;
        }
      }

      match /messages/{messageId} {
        allow read, create: if isWorkspaceMember(workspaceId);
        allow update, delete: if isSignedIn() && request.auth.uid == resource.data.userId;
      }
    }
  }
}
